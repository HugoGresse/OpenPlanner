VITE_FIREBASE_OPEN_PLANNER_PROJECT_ID=
VITE_FIREBASE_OPEN_PLANNER_API_KEY=
VITE_FIREBASE_OPEN_PLANNER_DOMAIN=
VITE_FIREBASE_OPEN_PLANNER_STORAGE_BUCKET=
VITE_FIREBASE_OPEN_PLANNER_APP_ID=
VITE_FIREBASE_OPEN_PLANNER_MEASUREMENT_ID=
VITE_FIREBASE_OPEN_PLANNER_API_URL=https://example.com
# Direct Cloud Functions URL (bypasses Firebase Hosting). Required for the
# chat SSE endpoint because Firebase Hosting buffers streamed responses.
# Example: https://europe-west1-<project>.cloudfunctions.net/api
VITE_FIREBASE_OPEN_PLANNER_FUNCTION_URL=http://127.0.0.1:5001/conferencecenterr/europe-west1/api/
VITE_OPEN_SPONSORS_URL=https://example.com
# Cap captcha service BASE URL used by the public speaker self-edit form.
# Passed as `data-cap-api-endpoint` to the <cap-widget>, so do include the site key at the end.
VITE_CAP_API_ENDPOINT=https://example.com/xxxxx/